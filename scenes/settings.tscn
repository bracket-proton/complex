[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/settings_menu.gd" id="1_settings"]

[node name="SettingsMenu" type="CanvasLayer"]
script = ExtResource("1_settings")

[node name="Overlay" type="Control" parent="."]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="BgRect" type="ColorRect" parent="Overlay"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.04, 0.03, 0.06, 1)

[node name="VBox" type="VBoxContainer" parent="Overlay"]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -150.0
offset_right = 150.0
offset_bottom = 150.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 24

[node name="Title" type="Label" parent="Overlay/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "設定"
horizontal_alignment = 1

[node name="BgmRow" type="HBoxContainer" parent="Overlay/VBox"]
layout_mode = 2
alignment = 1

[node name="Label" type="Label" parent="Overlay/VBox/BgmRow"]
layout_mode = 2
text = "BGM音量"

[node name="Slider" type="HSlider" parent="Overlay/VBox/BgmRow"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.0
max_value = 1.0
step = 0.01
value = 1.0

[node name="Value" type="Label" parent="Overlay/VBox/BgmRow"]
layout_mode = 2
text = "100%"

[node name="FontRow" type="HBoxContainer" parent="Overlay/VBox"]
layout_mode = 2
alignment = 1

[node name="Label" type="Label" parent="Overlay/VBox/FontRow"]
layout_mode = 2
text = "文字サイズ"

[node name="Slider" type="HSlider" parent="Overlay/VBox/FontRow"]
layout_mode = 2
size_flags_horizontal = 3
min_value = 0.5
max_value = 2.0
step = 0.1
value = 1.0

[node name="Value" type="Label" parent="Overlay/VBox/FontRow"]
layout_mode = 2
text = "100%"

[node name="BackButton" type="Button" parent="Overlay/VBox"]
layout_mode = 2
size_flags_horizontal = 4
text = "戻る"
